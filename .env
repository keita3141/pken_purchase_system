# LIFF設定
# LINE Developers コンソールで取得したLIFF IDを設定してください
# 例: VITE_LIFF_ID=1234567890-abcdefgh
VITE_LIFF_ID=2008952926-JJklUx0R

# LINE Login設定（パソコンからのログイン用）
# LINE Developers コンソールで取得したChannel IDを設定してください
VITE_LINE_LOGIN_CHANNEL_ID=2008952926
VITE_LINE_LOGIN_CALLBACK_URL=http://localhost:5173/auth/callback

# バックエンドAPI URL
VITE_API_BASE_URL=https://komapay.p-kmt.com

# デバッグログを本番環境でも強制表示（開発中のみ true にする）
VITE_FORCE_DEBUG=true
